---
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import TableOfContents from '../../../components/TableOfContents.astro';

export async function getStaticPaths() {
  const weeks = (await getCollection('fabacademy')).sort((a, b) => a.data.week - b.data.week);
  return weeks.map((week, idx) => ({
    params: { week: `week-${String(week.data.week).padStart(2, '0')}` },
    props: {
      week,
      prevWeek: idx > 0 ? weeks[idx - 1] : null,
      nextWeek: idx < weeks.length - 1 ? weeks[idx + 1] : null,
    },
  }));
}

const { week, prevWeek, nextWeek } = Astro.props;
const { Content, headings } = await render(week);
const { data } = week;

// Per-week machine/tool/part keywords — the specific terms searchers use.
// These power the meta description and JSON-LD keywords for each week.
const KEYWORDS: Record<number, string[]> = {
  1: ['PixelFace', 'POV display', 'persistence of vision', 'final project proposal', 'addressable LEDs'],
  2: ['Git', 'GitLab', 'HTML5UP Editorial', 'static site', 'version control', 'SSH keys'],
  3: ['Fusion 360', 'GIMP', 'Adobe Illustrator', 'MeshMixer', 'parametric CAD', 'raster vs vector'],
  4: ['laser cutter', 'vinyl cutter', 'Roland GX-24', 'press-fit kit', 'kerf', 'parametric design', 'RDworks'],
  5: ['FabISP', 'PCB milling', 'Roland MDX-20', 'FabTinyStar', 'ATtiny45', 'avrdude', 'fab modules'],
  6: ['3D printing', 'FDM', 'PLA', 'FlashForge', '3D scanning', 'Skanect', 'Fusion 360', 'slicer settings'],
  7: ['Eagle CAD', 'ATtiny44', 'PCB design', 'schematic', 'hello echo board', 'autorouter', 'DRC'],
  8: ['ShopBot', 'CNC router', 'Partworks', 'MDF', 'box joint', 'dogbone', 'feeds and speeds', 'Fusion 360'],
  9: ['ATtiny44', 'STM32', 'Blue Pill', 'Arduino', 'Atmel Studio', 'embedded C', 'Mbed', 'datasheet'],
  10: ['molding', 'casting', 'OOMOO 30', 'Smooth-Cast 305', 'silicone mold', 'machineable wax', 'Roland MDX-20'],
  11: ['ADXL345', 'accelerometer', 'rotary encoder', 'KY-040', 'joystick', 'I2C', 'optical encoder', 'sensors'],
  12: ['ATmega328p', 'BLDC motor', 'ESC', 'WS2812B', 'SSD1306 OLED', 'buck converter', 'output devices'],
  13: ['POV display', 'slip ring', 'hall effect sensor', 'NeoPixelBus', 'BLDC', 'rotating arm', 'bill of materials'],
  14: ['nRF24L01', 'RF24', 'wireless networking', 'I2C', 'SPI', 'telemetry', 'ATmega328p'],
  15: ['machine design', 'marble maze', 'MG995 servo', 'ATmega328p', 'mechanism', 'group project'],
  16: ['Processing', 'serial communication', 'GUI', 'scrollbar', 'interface programming', 'BLDC control'],
  18: ['wildcard', 'laser cutting', 'vinyl PCB', 'LED matrix', 'multilayer PCB', 'laser-cut cheese'],
  19: ['Creative Commons', 'CC BY-SA', 'patent', 'GPL', 'MIT license', 'open hardware', 'intellectual property'],
};
const weekKeywords = KEYWORDS[data.week] ?? [];
const keywordsStr = weekKeywords.join(', ');

const slug = `week-${String(data.week).padStart(2, '0')}`;
const pageUrl = new URL(`/projects/fab-academy/${slug}/`, Astro.site).toString();
const pageTitle = `${data.title} — Fab Academy 2019`;
// Keyword-rich, specific meta description (kept under ~160 chars).
const metaDesc = (
  `Fab Academy 2019, Week ${data.week} at Fab Lab CEPT: ${data.title}. ${data.assignment}`
  + (keywordsStr ? ` Covers ${keywordsStr}.` : '')
).slice(0, 300);

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      '@id': `${pageUrl}#article`,
      headline: `${data.title} — Fab Academy 2019 Week ${data.week}`,
      description: data.assignment,
      url: pageUrl,
      ...(data.heroImage && { image: new URL(data.heroImage, Astro.site).toString() }),
      author: {
        '@type': 'Person',
        '@id': 'https://samiulmakes.com/#person',
        name: 'Samiul Hoque',
        url: 'https://samiulmakes.com',
      },
      publisher: { '@id': 'https://samiulmakes.com/#person' },
      datePublished: '2019',
      inLanguage: 'en',
      articleSection: 'Fab Academy 2019',
      ...(weekKeywords.length && { keywords: weekKeywords.join(', ') }),
      isPartOf: { '@id': 'https://samiulmakes.com/#website' },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Samiul Hoque', item: 'https://samiulmakes.com/' },
        { '@type': 'ListItem', position: 2, name: 'Projects', item: 'https://samiulmakes.com/projects/' },
        { '@type': 'ListItem', position: 3, name: 'Fab Academy 2019', item: 'https://samiulmakes.com/projects/fab-academy/' },
        { '@type': 'ListItem', position: 4, name: data.title, item: pageUrl },
      ],
    },
  ],
};
---

<Base title={pageTitle} description={metaDesc} ogImage={data.heroImage} jsonLd={jsonLd}>
  <article class="container project" data-slug={slug}>
    <header>
      <a href="/projects/fab-academy/" class="back">← Fab Academy 2019</a>
      <span class="eyebrow">
        fabrication · 2019 · <span class="week-num">Week {data.week}</span>
      </span>
      <h1>{data.title}</h1>
      <p class="one-liner">{data.assignment}</p>
    </header>

    <div class="body-with-toc">
      <div class="body">
        <Content />
      </div>
      <aside class="toc-sidebar">
        <TableOfContents headings={headings} />
      </aside>
    </div>

    <nav class="week-nav">
      {prevWeek ? (
        <a href={`/projects/fab-academy/week-${String(prevWeek.data.week).padStart(2, '0')}/`} class="week-nav-prev">
          ← Week {prevWeek.data.week}
        </a>
      ) : <span />}
      <a href="/projects/fab-academy/" class="week-nav-hub">All weeks</a>
      {nextWeek ? (
        <a href={`/projects/fab-academy/week-${String(nextWeek.data.week).padStart(2, '0')}/`} class="week-nav-next">
          Week {nextWeek.data.week} →
        </a>
      ) : <span />}
    </nav>
  </article>
</Base>

<style>
  .project {
    padding-top: 2rem;
    padding-bottom: 2rem;
  }
  .back {
    font-family: var(--mono);
    font-size: 0.8125rem;
    text-decoration: none;
    color: var(--ink-mute);
    display: inline-block;
    margin-bottom: 1rem;
  }
  .back:hover { color: var(--accent); }
  .eyebrow {
    display: block;
    font-family: var(--mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin-bottom: 0.4rem;
  }
  .week-num { color: var(--accent); }
  .one-liner {
    font-size: 1rem;
    color: var(--ink-soft);
    margin: 0.25rem 0 1rem;
    line-height: 1.5;
  }
  .body-with-toc {
    display: grid;
    grid-template-columns: 1fr 14rem;
    gap: 3rem;
  }
  .toc-sidebar { align-self: stretch; }
  .hero { margin: 1rem 0 1.5rem; }
  .hero img { width: 100%; border-radius: 2px; }
  .body :global(p),
  .body :global(ul),
  .body :global(ol) {
    font-size: 0.9375rem;
    line-height: 1.7;
  }
  .body :global(ul),
  .body :global(ol) { padding-left: 1.25rem; }
  .body :global(li) { margin-bottom: 0.25rem; }
  .body :global(h2) {
    border-top: 1px solid var(--rule);
    padding-top: 1rem;
    margin-top: 1.5rem;
  }
  .body :global(blockquote) {
    border-left: 3px solid var(--accent);
    margin: 1rem 0;
    padding-left: 1rem;
    color: var(--ink-soft);
    font-style: italic;
  }
  .body :global(figure) {
    margin: 1.5rem 0;
    text-align: center;
  }
  .body :global(figure img) {
    width: 100%;
    height: auto;
    background: var(--bg-elev);
    border: 1px solid var(--rule);
    border-radius: 2px;
  }
  .body :global(figcaption) {
    font-family: var(--mono);
    font-size: 0.8125rem;
    color: var(--ink-mute);
    text-align: center;
    margin-top: 0.4rem;
    line-height: 1.4;
  }
  .body :global(img) {
    max-width: 100%;
    height: auto;
  }
  .body :global(pre) {
    background: var(--bg-elev);
    border: 1px solid var(--rule);
    border-radius: 2px;
    padding: 0.875rem 1rem;
    overflow-x: auto;
    font-size: 0.85rem;
    line-height: 1.5;
  }
  .body :global(code) {
    font-family: var(--mono);
    font-size: 0.85em;
  }
  .body :global(:not(pre) > code) {
    background: var(--bg-elev);
    padding: 0.1em 0.35em;
    border-radius: 2px;
  }
  .body :global(table) {
    border-collapse: collapse;
    width: 100%;
    margin: 1.25rem 0;
    font-size: 0.9rem;
  }
  .body :global(th),
  .body :global(td) {
    border: 1px solid var(--rule);
    padding: 0.4rem 0.6rem;
    text-align: left;
  }
  .body :global(hr) {
    border: none;
    border-top: 1px solid var(--rule);
    margin: 1.5rem 0;
  }

  .week-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--rule);
    margin-top: 2.5rem;
    padding-top: 1rem;
    font-family: var(--mono);
    font-size: 0.8125rem;
  }
  .week-nav a {
    text-decoration: none;
    color: var(--ink-mute);
  }
  .week-nav a:hover { color: var(--accent); }
  .week-nav-hub {
    color: var(--ink-soft) !important;
  }

  @media (max-width: 960px) {
    .body-with-toc { grid-template-columns: 1fr; }
    .toc-sidebar { display: none; }
  }
  @media (max-width: 600px) {
    .week-nav { flex-wrap: wrap; gap: 0.5rem; }
  }
</style>
