---
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import TableOfContents from '../../../components/TableOfContents.astro';

export async function getStaticPaths() {
  const weeks = (await getCollection('fabacademy')).sort((a, b) => a.data.week - b.data.week);
  return weeks.map((week, idx) => ({
    params: { week: `week-${String(week.data.week).padStart(2, '0')}` },
    props: {
      week,
      prevWeek: idx > 0 ? weeks[idx - 1] : null,
      nextWeek: idx < weeks.length - 1 ? weeks[idx + 1] : null,
    },
  }));
}

const { week, prevWeek, nextWeek } = Astro.props;
const { Content, headings } = await render(week);
const { data } = week;

const slug = `week-${String(data.week).padStart(2, '0')}`;
const pageUrl = new URL(`/projects/fab-academy/${slug}/`, Astro.site).toString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      '@id': `${pageUrl}#article`,
      headline: data.title,
      description: data.assignment,
      url: pageUrl,
      ...(data.heroImage && { image: new URL(data.heroImage, Astro.site).toString() }),
      author: {
        '@type': 'Person',
        '@id': 'https://samiulmakes.com/#person',
        name: 'Samiul Hoque',
        url: 'https://samiulmakes.com',
      },
      publisher: { '@id': 'https://samiulmakes.com/#person' },
      datePublished: '2019',
      isPartOf: { '@id': 'https://samiulmakes.com/#website' },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Samiul Hoque', item: 'https://samiulmakes.com/' },
        { '@type': 'ListItem', position: 2, name: 'Projects', item: 'https://samiulmakes.com/projects/' },
        { '@type': 'ListItem', position: 3, name: 'Fab Academy 2019', item: 'https://samiulmakes.com/projects/fab-academy/' },
        { '@type': 'ListItem', position: 4, name: data.title, item: pageUrl },
      ],
    },
  ],
};
---

<Base title={data.title} description={data.assignment} ogImage={data.heroImage} jsonLd={jsonLd}>
  <article class="container project" data-slug={slug}>
    <header>
      <a href="/projects/fab-academy/" class="back">← Fab Academy 2019</a>
      <span class="eyebrow">
        fabrication · 2019 · <span class="week-num">Week {data.week}</span>
      </span>
      <h1>{data.title}</h1>
      <p class="one-liner">{data.assignment}</p>
    </header>

    <div class="body-with-toc">
      <div class="body" data-gallery={JSON.stringify(data.gallery)}>
        {data.heroImage && (
          <figure class="hero">
            <img src={data.heroImage} alt={data.title} loading="eager" />
          </figure>
        )}
        <Content />
      </div>
      <aside class="toc-sidebar">
        <TableOfContents headings={headings} />
      </aside>
    </div>

    <nav class="week-nav">
      {prevWeek ? (
        <a href={`/projects/fab-academy/week-${String(prevWeek.data.week).padStart(2, '0')}/`} class="week-nav-prev">
          ← Week {prevWeek.data.week}
        </a>
      ) : <span />}
      <a href="/projects/fab-academy/" class="week-nav-hub">All weeks</a>
      {nextWeek ? (
        <a href={`/projects/fab-academy/week-${String(nextWeek.data.week).padStart(2, '0')}/`} class="week-nav-next">
          Week {nextWeek.data.week} →
        </a>
      ) : <span />}
    </nav>
  </article>
</Base>

<script>
  function interleaveGallery() {
    const body = document.querySelector<HTMLElement>('.body[data-gallery]');
    if (!body) return;

    const gallery: string[] = JSON.parse(body.dataset.gallery || '[]');
    if (!gallery.length) return;

    const h2s = Array.from(body.querySelectorAll(':scope > h2'));
    if (h2s.length < 2) {
      appendRemainder(body, gallery, 0);
      return;
    }

    const breaks = h2s.slice(1);
    const perBreak = Math.max(1, Math.ceil(gallery.length / breaks.length));
    let idx = 0;

    for (const h2 of breaks) {
      if (idx >= gallery.length) break;
      const count = Math.min(perBreak, gallery.length - idx);
      const figure = document.createElement('figure');
      figure.className = 'section-images' + (count === 1 ? ' single' : '');
      for (let i = 0; i < count; i++) {
        const a = document.createElement('a');
        a.href = gallery[idx];
        a.target = '_blank';
        a.rel = 'noopener';
        const img = document.createElement('img');
        img.src = gallery[idx];
        img.alt = '';
        img.loading = 'lazy';
        a.appendChild(img);
        figure.appendChild(a);
        idx++;
      }
      body.insertBefore(figure, h2);
    }

    appendRemainder(body, gallery, idx);
  }

  function appendRemainder(body: HTMLElement, gallery: string[], fromIdx: number) {
    if (fromIdx >= gallery.length) return;
    const figure = document.createElement('figure');
    figure.className = 'section-images remainder';
    for (let i = fromIdx; i < gallery.length; i++) {
      const a = document.createElement('a');
      a.href = gallery[i];
      a.target = '_blank';
      a.rel = 'noopener';
      const img = document.createElement('img');
      img.src = gallery[i];
      img.alt = '';
      img.loading = 'lazy';
      a.appendChild(img);
      figure.appendChild(a);
    }
    body.appendChild(figure);
  }

  interleaveGallery();
  document.addEventListener('astro:after-swap', interleaveGallery);
</script>

<style>
  .project {
    padding-top: 2rem;
    padding-bottom: 2rem;
  }
  .back {
    font-family: var(--mono);
    font-size: 0.8125rem;
    text-decoration: none;
    color: var(--ink-mute);
    display: inline-block;
    margin-bottom: 1rem;
  }
  .back:hover { color: var(--accent); }
  .eyebrow {
    display: block;
    font-family: var(--mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin-bottom: 0.4rem;
  }
  .week-num { color: var(--accent); }
  .one-liner {
    font-size: 1rem;
    color: var(--ink-soft);
    margin: 0.25rem 0 1rem;
    line-height: 1.5;
  }
  .body-with-toc {
    display: grid;
    grid-template-columns: 1fr 14rem;
    gap: 3rem;
  }
  .toc-sidebar { align-self: stretch; }
  .hero { margin: 1rem 0 1.5rem; }
  .hero img { width: 100%; border-radius: 2px; }
  .body :global(p),
  .body :global(ul),
  .body :global(ol) {
    font-size: 0.9375rem;
    line-height: 1.7;
  }
  .body :global(ul),
  .body :global(ol) { padding-left: 1.25rem; }
  .body :global(li) { margin-bottom: 0.25rem; }
  .body :global(h2) {
    border-top: 1px solid var(--rule);
    padding-top: 1rem;
    margin-top: 1.5rem;
  }
  .body :global(blockquote) {
    border-left: 3px solid var(--accent);
    margin: 1rem 0;
    padding-left: 1rem;
    color: var(--ink-soft);
    font-style: italic;
  }
  .body :global(figure:not(.hero):not(.section-images)) { margin: 1.25rem 0; }
  .body :global(figcaption) {
    font-family: var(--mono);
    font-size: 0.8125rem;
    color: var(--ink-mute);
    text-align: center;
    margin-top: 0.4rem;
    line-height: 1.4;
  }
  .body :global(.section-images) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
    margin: 1.25rem 0;
  }
  .body :global(.section-images.single) { grid-template-columns: 1fr; }
  .body :global(.section-images.remainder) {
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    border-top: 1px solid var(--rule);
    padding-top: 1.25rem;
    margin-top: 1.5rem;
  }
  .body :global(.section-images img) {
    width: 100%;
    height: auto;
    object-fit: contain;
    background: var(--bg-elev);
    border: 1px solid var(--rule);
    transition: opacity 0.2s ease;
  }
  .body :global(.section-images a:hover img) { opacity: 0.85; }
  .body :global(img) {
    max-width: 100%;
    height: auto;
    border: 1px solid var(--rule);
    border-radius: 2px;
  }

  .week-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--rule);
    margin-top: 2.5rem;
    padding-top: 1rem;
    font-family: var(--mono);
    font-size: 0.8125rem;
  }
  .week-nav a {
    text-decoration: none;
    color: var(--ink-mute);
  }
  .week-nav a:hover { color: var(--accent); }
  .week-nav-hub {
    color: var(--ink-soft) !important;
  }

  @media (max-width: 960px) {
    .body-with-toc { grid-template-columns: 1fr; }
    .toc-sidebar { display: none; }
  }
  @media (max-width: 600px) {
    .week-nav { flex-wrap: wrap; gap: 0.5rem; }
  }
</style>
