---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';

const weeks = (await getCollection('fabacademy')).sort(
  (a, b) => a.data.week - b.data.week,
);

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      '@id': 'https://samiulmakes.com/projects/fab-academy/#collection',
      name: 'Fab Academy 2019 — Samiul Hoque',
      description: '19 weeks of digital fabrication documentation from Fab Academy 2019 at Fab Lab CEPT.',
      url: 'https://samiulmakes.com/projects/fab-academy/',
      author: { '@id': 'https://samiulmakes.com/#person' },
      isPartOf: { '@id': 'https://samiulmakes.com/#website' },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Samiul Hoque', item: 'https://samiulmakes.com/' },
        { '@type': 'ListItem', position: 2, name: 'Projects', item: 'https://samiulmakes.com/projects/' },
        { '@type': 'ListItem', position: 3, name: 'Fab Academy 2019', item: 'https://samiulmakes.com/projects/fab-academy/' },
      ],
    },
  ],
};
---

<Base
  title="Fab Academy 2019"
  description="19 weeks of digital fabrication documentation from Fab Academy 2019 at Fab Lab CEPT, Ahmedabad."
  ogImage="/images/fabacademy/presentation.png"
  jsonLd={jsonLd}
>
  <article class="container hub">
    <header>
      <a href="/projects/" class="back">← All projects</a>
      <span class="eyebrow">fabrication · 2019</span>
      <h1>Fab Academy 2019</h1>
      <p class="one-liner">
        19 weeks of digital fabrication at Fab Lab CEPT, Ahmedabad. Each week
        is a new topic, a new machine, and a build that has to be documented to
        count.
      </p>
    </header>

    <section class="context">
      <p>
        Fab Academy is a distributed programme run out of MIT's Center for Bits
        and Atoms. Neil Gershenfeld teaches the main classes live each week;
        local instructors run things on the ground. I did the 2019 cycle at Fab
        Lab CEPT. My local instructor was Ohad Meyuhas (Stratasys); my global
        instructor was Francisco Sanchez (TECSUP).
      </p>
      <p>
        The weeks below are the full build logs — scraped from the original
        submission and re-hosted here because the source CSS broke. Content is
        mine; the Fab Academy programme is by the Fab Foundation.
      </p>
    </section>

    <section class="weeks-section">
      <h2 class="section-label">Weekly assignments</h2>
      <div class="tiles">
        {weeks.map((w) => {
          const slug = `week-${String(w.data.week).padStart(2, '0')}`;
          return (
            <a href={`/projects/fab-academy/${slug}/`} class="tile">
              {w.data.heroImage && (
                <div class="tile-img">
                  <img src={w.data.heroImage} alt={w.data.title} loading="lazy" />
                </div>
              )}
              {!w.data.heroImage && <div class="tile-img placeholder" />}
              <div class="tile-body">
                <span class="week-badge">W{String(w.data.week).padStart(2, '0')}</span>
                <h3>{w.data.title}</h3>
                <p>{w.data.assignment}</p>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  </article>
</Base>

<style>
  .hub {
    padding-top: 2rem;
    padding-bottom: 3rem;
  }
  .back {
    font-family: var(--mono);
    font-size: 0.8125rem;
    text-decoration: none;
    color: var(--ink-mute);
    display: inline-block;
    margin-bottom: 1rem;
  }
  .back:hover { color: var(--accent); }
  .eyebrow {
    display: block;
    font-family: var(--mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin-bottom: 0.4rem;
  }
  .one-liner {
    font-size: 1rem;
    color: var(--ink-soft);
    margin: 0.25rem 0 1.5rem;
    line-height: 1.5;
  }
  .context {
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding: 1rem 0;
    margin-bottom: 2rem;
  }
  .context p {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--ink-soft);
    margin: 0 0 0.75rem;
  }
  .context p:last-child { margin-bottom: 0; }
  .section-label {
    font-family: var(--mono);
    font-size: 0.8125rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mute);
    border-top: 1px solid var(--rule);
    padding-top: 0.75rem;
    margin-top: 0;
    margin-bottom: 1.25rem;
  }
  .tiles {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem;
  }
  .tile {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--ink);
    border: 1px solid var(--rule);
    border-radius: 2px;
    overflow: hidden;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .tile:hover {
    border-color: var(--accent);
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  }
  .tile-img {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--bg-elev);
  }
  .tile-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.2s ease;
  }
  .tile:hover .tile-img img { opacity: 0.9; }
  .tile-img.placeholder {
    background: repeating-linear-gradient(
      45deg,
      var(--bg-elev),
      var(--bg-elev) 4px,
      var(--rule) 4px,
      var(--rule) 5px
    );
  }
  .tile-body {
    padding: 0.875rem 1rem 1rem;
    flex: 1;
  }
  .week-badge {
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mute);
    display: block;
    margin-bottom: 0.3rem;
  }
  .tile-body h3 {
    font-size: 0.9375rem;
    font-weight: 600;
    margin: 0 0 0.4rem;
    line-height: 1.3;
  }
  .tile-body p {
    font-size: 0.8125rem;
    color: var(--ink-soft);
    margin: 0;
    line-height: 1.5;
  }

  @media (max-width: 600px) {
    .tiles {
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
    }
  }
  @media (max-width: 380px) {
    .tiles {
      grid-template-columns: 1fr;
    }
  }
</style>
