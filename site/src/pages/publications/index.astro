---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('publications', ({ data }) => !data.draft);
const projects = await getCollection('projects', ({ data }) => !data.draft);
const projectIds = new Set(projects.map((p) => p.id));

const groups = [
  {
    key: 'published',
    label: 'Published',
    note: 'Peer-reviewed conference papers.',
    items: all
      .filter((p) => p.data.status === 'published')
      .sort((a, b) => b.data.year - a.data.year || a.data.order - b.data.order),
  },
  {
    key: 'in-preparation',
    label: 'In preparation',
    note: 'Manuscripts being prepared for submission.',
    items: all
      .filter((p) => p.data.status === 'in-preparation')
      .sort((a, b) => b.data.year - a.data.year || a.data.order - b.data.order),
  },
  {
    key: 'thesis',
    label: 'Thesis',
    note: 'Undergraduate thesis at IUB.',
    items: all
      .filter((p) => p.data.status === 'thesis')
      .sort((a, b) => b.data.year - a.data.year || a.data.order - b.data.order),
  },
].filter((g) => g.items.length > 0);

function formatAuthors(authors: string[]) {
  return authors.map((a) =>
    a === 'Samiul Hoque' || a === 'Samiul Haque'
      ? { name: a, self: true }
      : { name: a, self: false }
  );
}
---

<Base title="Publications" description="Peer-reviewed conference papers and thesis work by Samiul Hoque.">
  <article class="container publications">
    <header>
      <span class="eyebrow">Publications</span>
      <h1>Papers &amp; writing.</h1>
      <p class="lede">
        Conference papers from coursework at Independent University,
        Bangladesh, plus thesis work in preparation for journal submission.
      </p>
    </header>

    {groups.map((group) => (
      <section class="group">
        <header class="group-head">
          <h2 class="section-label">{group.label}</h2>
          {group.note && <p class="group-note">{group.note}</p>}
        </header>

        <ul class="pub-list">
          {group.items.map((p) => (
            <li class="pub">
              <div class="pub-meta">
                <span class="pub-year">{p.data.year}</span>
                {p.data.venueShort && <span class="pub-venue">{p.data.venueShort}</span>}
              </div>
              <div class="pub-body">
                <h3 class="pub-title">
                  {p.data.url ? (
                    <a href={p.data.url} target="_blank" rel="noopener">{p.data.title}</a>
                  ) : (
                    p.data.title
                  )}
                </h3>
                <p class="pub-authors">
                  {formatAuthors(p.data.authors).map((a, i) => (
                    <>
                      {i > 0 && ', '}
                      <span class={a.self ? 'self' : ''}>{a.name}</span>
                    </>
                  ))}
                </p>
                <p class="pub-venue-full">
                  <em>{p.data.venue}</em>
                  {p.data.location && <>, {p.data.location}</>}
                  {p.data.pages && <>, pp. {p.data.pages}</>}.
                </p>
                {p.data.keywords.length > 0 && (
                  <ul class="pub-keywords">
                    {p.data.keywords.map((k) => (
                      <li>{k}</li>
                    ))}
                  </ul>
                )}
                <ul class="pub-links">
                  {p.data.doi && (
                    <li>
                      <a href={`https://doi.org/${p.data.doi}`} target="_blank" rel="noopener">
                        doi:{p.data.doi}
                      </a>
                    </li>
                  )}
                  {p.data.pdf && (
                    <li>
                      <a href={p.data.pdf}>PDF</a>
                    </li>
                  )}
                  {p.data.relatedProject && projectIds.has(p.data.relatedProject) && (
                    <li>
                      <a href={`/projects/${p.data.relatedProject}/`}>Project page →</a>
                    </li>
                  )}
                </ul>
              </div>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </article>
</Base>

<style>
  .publications {
    padding: 2rem 0 2rem;
  }
  .publications header h1 {
    font-size: 1.625rem;
    margin: 0.25rem 0 0.5rem;
  }
  .lede {
    font-size: 1rem;
    line-height: 1.5;
    color: var(--ink-soft);
  }

  .group { margin-top: 2rem; }
  .group-head { margin-bottom: 0.75rem; }
  .section-label {
    font-family: var(--mono);
    font-size: 0.8125rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-mute);
    border-top: 1px solid var(--rule);
    padding-top: 0.75rem;
    margin: 0 0 0.25rem;
    font-weight: 500;
  }
  .group-note {
    color: var(--ink-mute);
    font-size: 0.875rem;
    margin: 0;
  }

  .pub-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .pub {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: 1.5rem;
    padding: 1rem 0;
    border-top: 1px solid var(--rule);
    align-items: start;
  }
  .pub-meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .pub-year {
    font-family: var(--mono);
    font-size: 0.875rem;
    color: var(--accent);
    letter-spacing: 0.04em;
  }
  .pub-venue {
    font-family: var(--mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }
  .pub-title {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.35;
    margin: 0 0 0.5rem;
  }
  .pub-title a {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
  }
  .pub-title a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
  .pub-authors {
    color: var(--ink-soft);
    font-size: 0.9375rem;
    margin: 0 0 0.5rem;
    line-height: 1.5;
  }
  .pub-authors .self {
    color: var(--ink);
    font-weight: 500;
  }
  .pub-venue-full {
    color: var(--ink-mute);
    font-size: 0.9375rem;
    margin: 0 0 0.75rem;
  }
  .pub-keywords {
    list-style: none;
    padding: 0;
    margin: 0 0 0.75rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }
  .pub-keywords li {
    font-family: var(--mono);
    font-size: 0.6875rem;
    letter-spacing: 0.04em;
    color: var(--ink-mute);
    background: var(--bg-elev);
    border: 1px solid var(--rule);
    padding: 0.125rem 0.5rem;
  }
  .pub-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .pub-links a {
    font-family: var(--mono);
    font-size: 0.8125rem;
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 1px;
  }

  @media (max-width: 720px) {
    .pub { grid-template-columns: 1fr; gap: 0.5rem; }
    .pub-meta { flex-direction: row; gap: 0.75rem; align-items: baseline; }
  }
</style>
