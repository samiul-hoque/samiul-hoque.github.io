---
const links = [
  { href: '/', label: 'Home' },
  { href: '/projects/', label: 'Projects' },
  { href: '/publications/', label: 'Publications' },
  { href: '/about/', label: 'About' },
];
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<nav class="nav">
  <div class="container nav-inner">
    <a href="/" class="brand"><span>Samiul</span> <span>Hoque</span></a>
    <ul>
      {links.map((link) => {
        const target = link.href.replace(/\/$/, '') || '/';
        const active = pathname === target;
        return (
          <li><a href={link.href} class={active ? 'active' : ''}>{link.label}</a></li>
        );
      })}
    </ul>
  </div>
</nav>

<style>
  .nav {
    border-bottom: 1px solid var(--rule);
    background: var(--bg);
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(8px);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding-top: 1rem;
    padding-bottom: 1rem;
  }
  .brand {
    font-family: var(--sans);
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 1.5rem;
  }
  ul a {
    font-family: var(--mono);
    font-size: 0.875rem;
    text-decoration: none;
    color: var(--ink-soft);
    padding-bottom: 2px;
    border-bottom: 1px solid transparent;
  }
  ul a:hover {
    color: var(--ink);
  }
  ul a.active {
    color: var(--ink);
    border-bottom-color: var(--accent);
  }

  @media (max-width: 540px) {
    /* Treat the name as a stacked two-line wordmark, clearly distinct from
       the nav links, with the links pushed to the right. */
    .nav-inner { gap: 1rem; }
    .brand {
      font-size: 1.2rem;
      font-weight: 700;
      line-height: 1.05;
      letter-spacing: -0.02em;
    }
    .brand span { display: block; }
    ul {
      gap: 0.75rem 1rem;
      flex-wrap: wrap;
      justify-content: flex-end;
    }
    ul a { font-size: 0.8125rem; }
  }
</style>
